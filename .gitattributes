# Normalize line endings: auto-detect text, store LF in repo
* text=auto eol=lf

# Explicitly text
*.cs        text diff=csharp
*.csproj    text
*.sln       text eol=crlf
*.props     text
*.targets   text
*.axaml     text
*.xaml      text
*.json      text
*.md        text
*.yml       text
*.yaml      text
*.manifest  text
.gitignore  text
.gitattributes text
.editorconfig  text

# Binary assets (never normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.pdf       binary
