<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Custom vector glyphs for PathIcon (tinted by the host's Foreground; theme-aware, cross-platform).
       Authored in a 0..16 / 0..24 box; PathIcon stretches Uniform to its Width/Height. -->

  <!-- Sidebar / "panel" glyph: a rounded frame with a solid left column (the right content area is an
       EvenOdd hole). The universal "show/hide the side panel" affordance; used on the outline toggle. -->
  <GeometryGroup x:Key="IconSidebar" FillRule="EvenOdd">
    <RectangleGeometry Rect="1,2,14,12" RadiusX="2.2" RadiusY="2.2"/>
    <RectangleGeometry Rect="5.6,3.4,8.6,9.2" RadiusX="1" RadiusY="1"/>
  </GeometryGroup>

  <!-- Document / "page" glyph: a portrait page with a folded top-right corner (dog-ear), drawn as an
       outline via EvenOdd (outer silhouette minus inner). Used on the decorative-background toggle;
       a PathIcon (not the Symbols font) so its thin strokes render crisp, with no subpixel colour
       fringing like the font glyph had. -->
  <GeometryGroup x:Key="IconDocument" FillRule="EvenOdd">
    <PathGeometry Figures="M5,2 L14,2 L19,7 L19,22 L5,22 Z"/>
    <PathGeometry Figures="M7,4 L13,4 L13,8 L17,8 L17,20 L7,20 Z"/>
  </GeometryGroup>

  <!-- The chrome icons below replace FluentAvalonia font SymbolIcons (Find / Code / per-tab type):
       PathIcons are geometry, immune to the Symbols-font load race that left them as .notdef boxes. -->

  <!-- Search / "magnifier": a ring (EvenOdd outer minus inner ellipse) plus a diagonal handle. -->
  <GeometryGroup x:Key="IconSearch" FillRule="EvenOdd">
    <EllipseGeometry Center="10,10" RadiusX="6.6" RadiusY="6.6"/>
    <EllipseGeometry Center="10,10" RadiusX="4.2" RadiusY="4.2"/>
    <PathGeometry Figures="M14.6,15.8 L15.8,14.6 L21,19.8 L19.8,21 Z"/>
  </GeometryGroup>

  <!-- Code / "&lt; &gt;": two solid chevrons (the universal source-view affordance). -->
  <GeometryGroup x:Key="IconCode">
    <PathGeometry Figures="M9.4,6.6 L11,8.2 L7.2,12 L11,15.8 L9.4,17.4 L4,12 Z"/>
    <PathGeometry Figures="M14.6,6.6 L13,8.2 L16.8,12 L13,15.8 L14.6,17.4 L20,12 Z"/>
  </GeometryGroup>

  <!-- Word-wrap / "↵": three text bars; the 2nd wraps with a hooked return arrow back to the left
       (the universal word-wrap affordance). Filled bars + a solid hook so it reads at 16px. -->
  <GeometryGroup x:Key="IconWrap" FillRule="NonZero">
    <RectangleGeometry Rect="3,5,18,1.8" RadiusX="0.9" RadiusY="0.9"/>
    <RectangleGeometry Rect="3,11,12.5,1.8" RadiusX="0.9" RadiusY="0.9"/>
    <!-- return hook: out from the line end, curving down and back left -->
    <PathGeometry Figures="M15.5,11 C19.2,11 19.6,16.9 15,16.9 L12.6,16.9 L12.6,15.1 L15,15.1 C16.9,15.1 16.8,12.8 15.5,12.8 Z"/>
    <!-- arrowhead at the hook's left end, pointing left -->
    <PathGeometry Figures="M13.2,14 L9.3,16 L13.2,18 Z"/>
    <RectangleGeometry Rect="3,17,5,1.8" RadiusX="0.9" RadiusY="0.9"/>
  </GeometryGroup>

  <!-- Line-numbers / "#": a slim numbered-list glyph — a left column of short ticks (the numbers)
       beside three longer text bars. -->
  <GeometryGroup x:Key="IconLineNumbers">
    <RectangleGeometry Rect="3,5,2.6,1.8" RadiusX="0.6" RadiusY="0.6"/>
    <RectangleGeometry Rect="3,11,2.6,1.8" RadiusX="0.6" RadiusY="0.6"/>
    <RectangleGeometry Rect="3,17,2.6,1.8" RadiusX="0.6" RadiusY="0.6"/>
    <RectangleGeometry Rect="8,5,13,1.8" RadiusX="0.9" RadiusY="0.9"/>
    <RectangleGeometry Rect="8,11,13,1.8" RadiusX="0.9" RadiusY="0.9"/>
    <RectangleGeometry Rect="8,17,9.5,1.8" RadiusX="0.9" RadiusY="0.9"/>
  </GeometryGroup>

  <!-- Settings / "sliders": three thin bars with fatter knobs that bulge past them (Nonzero union).
       A tune glyph reads as config without the fiddly tooth geometry of a gear. -->
  <GeometryGroup x:Key="IconSettings">
    <RectangleGeometry Rect="3,6.4,18,1.6" RadiusX="0.8" RadiusY="0.8"/>
    <RectangleGeometry Rect="3,11.2,18,1.6" RadiusX="0.8" RadiusY="0.8"/>
    <RectangleGeometry Rect="3,16,18,1.6" RadiusX="0.8" RadiusY="0.8"/>
    <EllipseGeometry Center="8,7.2" RadiusX="2.4" RadiusY="2.4"/>
    <EllipseGeometry Center="15,12" RadiusX="2.4" RadiusY="2.4"/>
    <EllipseGeometry Center="10,16.8" RadiusX="2.4" RadiusY="2.4"/>
  </GeometryGroup>

  <!-- Heart / "support": a single solid filled heart (two lobes meeting at the top dimple, tapering
       to the bottom point). Tinted by Foreground; used on the title-strip "Поддержать автора" button. -->
  <GeometryGroup x:Key="IconHeart">
    <PathGeometry Figures="M12,21 C12,21 3,14.6 3,8.6 C3,5.6 5.2,3.6 7.8,3.6 C9.6,3.6 11.1,4.7 12,6.1 C12.9,4.7 14.4,3.6 16.2,3.6 C18.8,3.6 21,5.6 21,8.6 C21,14.6 12,21 12,21 Z"/>
  </GeometryGroup>

  <!-- Copy / "two sheets": a front sheet (rounded frame via EvenOdd) with a back sheet peeking
       top-left. Used on the donation address Copy buttons. -->
  <GeometryGroup x:Key="IconCopy" FillRule="EvenOdd">
    <RectangleGeometry Rect="8.5,8.5,11.5,12" RadiusX="2.4" RadiusY="2.4"/>
    <RectangleGeometry Rect="10.4,10.4,7.7,8.2"/>
    <PathGeometry Figures="M4.5,3.5 L14.5,3.5 L14.5,5.4 L6.4,5.4 L6.4,15.5 L4.5,15.5 Z"/>
  </GeometryGroup>

  <!-- Check / "done": a chunky checkmark (filled stroke). Swaps in on the Copy button after a copy. -->
  <GeometryGroup x:Key="IconCheck">
    <PathGeometry Figures="M9.6,16.2 L4.4,11 L6.2,9.2 L9.6,12.6 L17.8,4.4 L19.6,6.2 Z"/>
  </GeometryGroup>

  <!-- External link / "open out": a bracket frame (EvenOdd) plus an arrow leaving the top-right. -->
  <GeometryGroup x:Key="IconExternalLink" FillRule="EvenOdd">
    <PathGeometry Figures="M4.5,6.5 C4.5,5.4 5.4,4.5 6.5,4.5 L11,4.5 L11,6.5 L6.5,6.5 L6.5,17.5 L17.5,17.5 L17.5,13 L19.5,13 L19.5,17.5 C19.5,18.6 18.6,19.5 17.5,19.5 L6.5,19.5 C5.4,19.5 4.5,18.6 4.5,17.5 Z"/>
    <PathGeometry Figures="M13,4.5 L19.5,4.5 L19.5,11 L17.6,11 L17.6,7.74 L11.83,13.5 L10.5,12.17 L16.26,6.4 L13,6.4 Z"/>
  </GeometryGroup>

  <!-- Card / "payment": a rounded card outline (EvenOdd) with a solid magnetic stripe band. -->
  <GeometryGroup x:Key="IconCard" FillRule="EvenOdd">
    <RectangleGeometry Rect="3,5.5,18,13" RadiusX="2.6" RadiusY="2.6"/>
    <RectangleGeometry Rect="5,7.5,14,9" RadiusX="1" RadiusY="1"/>
    <RectangleGeometry Rect="3,8.6,18,2.6"/>
  </GeometryGroup>

  <!-- Admonition / callout type glyphs (Obsidian-style: icon leads the title; tinted by the per-type
       Foreground in Admonitions.axaml). Each is an EvenOdd frame (outer minus inner) with the inner
       mark sitting in the hole, so it fills back in — the established ring/outline pattern above. -->

  <!-- Note → "info": a ring with an i (dot + stem). -->
  <GeometryGroup x:Key="IconAdmNote" FillRule="EvenOdd">
    <EllipseGeometry Center="12,12" RadiusX="9.3" RadiusY="9.3"/>
    <EllipseGeometry Center="12,12" RadiusX="7.4" RadiusY="7.4"/>
    <EllipseGeometry Center="12,7.9" RadiusX="1.25" RadiusY="1.25"/>
    <RectangleGeometry Rect="10.75,10.2,2.5,7" RadiusX="1.1" RadiusY="1.1"/>
  </GeometryGroup>

  <!-- Tip → "lightbulb": a glass ring with a filament line and a solid base. -->
  <GeometryGroup x:Key="IconAdmTip" FillRule="EvenOdd">
    <EllipseGeometry Center="12,9.5" RadiusX="6.2" RadiusY="6.2"/>
    <EllipseGeometry Center="12,9.5" RadiusX="4.4" RadiusY="4.4"/>
    <RectangleGeometry Rect="11.2,8,1.6,4.2" RadiusX="0.7" RadiusY="0.7"/>
    <RectangleGeometry Rect="9.6,15.4,4.8,1.7" RadiusX="0.8" RadiusY="0.8"/>
    <RectangleGeometry Rect="10.4,17.5,3.2,1.5" RadiusX="0.7" RadiusY="0.7"/>
  </GeometryGroup>

  <!-- Important → "message": a rounded speech bubble with a tail and a ! inside. -->
  <GeometryGroup x:Key="IconAdmImportant" FillRule="EvenOdd">
    <RectangleGeometry Rect="3,3.5,18,13" RadiusX="3" RadiusY="3"/>
    <RectangleGeometry Rect="5.2,5.7,13.6,8.6" RadiusX="1.6" RadiusY="1.6"/>
    <PathGeometry Figures="M8,15.5 L8,20.5 L13,15.5 Z"/>
    <RectangleGeometry Rect="11.1,7.4,1.8,4.2" RadiusX="0.8" RadiusY="0.8"/>
    <EllipseGeometry Center="12,13.2" RadiusX="1.05" RadiusY="1.05"/>
  </GeometryGroup>

  <!-- Warning → "alert": a triangle frame with a ! inside. -->
  <GeometryGroup x:Key="IconAdmWarning" FillRule="EvenOdd">
    <PathGeometry Figures="M12,2.8 L22.2,20.2 L1.8,20.2 Z"/>
    <PathGeometry Figures="M12,7.2 L18.4,18.2 L5.6,18.2 Z"/>
    <RectangleGeometry Rect="10.9,10,2.2,4.8" RadiusX="1" RadiusY="1"/>
    <EllipseGeometry Center="12,16.7" RadiusX="1.15" RadiusY="1.15"/>
  </GeometryGroup>

  <!-- Caution → "stop": an octagon frame with a ! inside (distinct from the warning triangle). -->
  <GeometryGroup x:Key="IconAdmCaution" FillRule="EvenOdd">
    <PathGeometry Figures="M8.5,3 L15.5,3 L21,8.5 L21,15.5 L15.5,21 L8.5,21 L3,15.5 L3,8.5 Z"/>
    <PathGeometry Figures="M9.5,5.3 L14.5,5.3 L18.7,9.5 L18.7,14.5 L14.5,18.7 L9.5,18.7 L5.3,14.5 L5.3,9.5 Z"/>
    <RectangleGeometry Rect="10.9,7.6,2.2,5" RadiusX="1" RadiusY="1"/>
    <EllipseGeometry Center="12,15.4" RadiusX="1.15" RadiusY="1.15"/>
  </GeometryGroup>

  <!-- Image / "picture": a frame (EvenOdd outer minus inner rect) with a sun and a mountain inside
       (each adds one more crossing inside the frame's hole, so EvenOdd fills them). -->
  <GeometryGroup x:Key="IconImage" FillRule="EvenOdd">
    <RectangleGeometry Rect="3,4,18,16" RadiusX="2.4" RadiusY="2.4"/>
    <RectangleGeometry Rect="5,6,14,12" RadiusX="1.2" RadiusY="1.2"/>
    <EllipseGeometry Center="9,10" RadiusX="1.8" RadiusY="1.8"/>
    <PathGeometry Figures="M6,18 L11,12.5 L14,15.5 L16.5,13 L19,18 Z"/>
  </GeometryGroup>

</ResourceDictionary>
