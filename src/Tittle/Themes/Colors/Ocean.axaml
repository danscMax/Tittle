<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Ocean (ported dark set) ============
         A deep blue-teal variant. Inherits the Dark variant: only the surface tokens are
         overridden here — admonitions, cv-* decorations etc. fall back to Dark.axaml. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0A0D12" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#0D1116" />
    <!-- Opaque outline-sidebar surface (see Dark.axaml). -->
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#0F1318" />

    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#17252F" Offset="0" />
        <GradientStop Color="#121E28" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#14222C" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#233442" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#DCE7EF" />
    <Color x:Key="ChromeForegroundColor">#DCE7EF</Color>
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#8FA3B3" />

    <SolidColorBrush x:Key="AccentBrush" Color="#2EC8BE" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#4FD8CF" />

    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#0F1B25" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#A4BACA" />

</ResourceDictionary>
