<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Slim, theme-tinted scrollbars (editor + lists + preview). Two things are needed:
       1. The app's own ScrollViewers honour a Thumb.Background style (see below) — that already gave
          the preview/lists a dark thumb.
       2. AvaloniaEdit's editor ScrollViewer ignores that and paints its thumb from the FluentAvalonia
          WinUI-named resource brushes (ScrollBarThumb*Background) — the default reads light-grey on the
          dark editor. We override those keys here (this Styles dict is included LAST in App.axaml, after
          FluentAvaloniaTheme, so it wins) per theme variant. This is what actually retints the editor. -->
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <!-- NOTE: the Avalonia 11.3 Fluent ScrollBar Thumb reads its fill from
             ScrollBarPanningThumbBackground (normal) and ScrollBarThumbFill{PointerOver,Pressed,Disabled}
             — NOT the WinUI-style ScrollBarThumb*Background names. Overriding only the latter left the
             expanded/hover thumb on the default (light) brush over a dark theme. We set BOTH families:
             the correct Fluent keys retint the app's ScrollViewers (welcome list, preview, panels), and
             the legacy ScrollBarThumb*Background keys are kept for AvaloniaEdit's own scrollbar.
             Midnight/Ocean (and the other dark-derived variants) inherit these via the Dark parent. -->
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="#52525F" />
          <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="#6A6A78" />
          <SolidColorBrush x:Key="ScrollBarThumbFillPressed" Color="#7C7C8C" />
          <SolidColorBrush x:Key="ScrollBarThumbFillDisabled" Color="#33333D" />
          <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#52525F" />
          <SolidColorBrush x:Key="ScrollBarThumbPointerOverBackground" Color="#6A6A78" />
          <SolidColorBrush x:Key="ScrollBarThumbPressedBackground" Color="#7C7C8C" />
          <SolidColorBrush x:Key="ScrollBarThumbDisabledBackground" Color="#33333D" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="#C2C2CE" />
          <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="#A6A6B6" />
          <SolidColorBrush x:Key="ScrollBarThumbFillPressed" Color="#8E8E9E" />
          <SolidColorBrush x:Key="ScrollBarThumbFillDisabled" Color="#E2E2EA" />
          <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#C2C2CE" />
          <SolidColorBrush x:Key="ScrollBarThumbPointerOverBackground" Color="#A6A6B6" />
          <SolidColorBrush x:Key="ScrollBarThumbPressedBackground" Color="#8E8E9E" />
          <SolidColorBrush x:Key="ScrollBarThumbDisabledBackground" Color="#E2E2EA" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Slim + rounded; Background tints the app ScrollViewers' thumbs (the editor uses the resources above). -->
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource ScrollBarThumbBackground}" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ScrollBar:vertical /template/ Thumb">
    <Setter Property="MinWidth" Value="7" />
  </Style>
  <Style Selector="ScrollBar:horizontal /template/ Thumb">
    <Setter Property="MinHeight" Value="7" />
  </Style>
  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource ScrollBarThumbPointerOverBackground}" />
  </Style>

</Styles>
