<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Modal card: the rounded, shadowed surface every standalone modal (ModalWindow + the command
       palette) draws its content on. Holds the shared chrome (the transparent window shape lives in
       ModalWindow's ctor); each window keeps only its own Padding. TextElement.Foreground sets the
       default text colour once via inheritance — muted labels and the accent button still override it
       (their own Foreground wins over the inherited default), so no per-control Foreground is needed. -->
  <Style Selector="Border.modalcard">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}"/>
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BoxShadow" Value="{DynamicResource ChromeShadow}"/>
    <Setter Property="Margin" Value="14"/>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource ChromeForegroundBrush}"/>
  </Style>
  <!-- CheckBox/RadioButton resolve their label colour from their own Foreground property (the Fluent
       theme default wins over an inherited TextElement.Foreground), so set it explicitly for the ones
       inside a modal card. Scoped to those two controls only — the accent button keeps its own
       Foreground, and muted section labels override with an inline brush. -->
  <Style Selector="Border.modalcard CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}"/>
  </Style>
  <Style Selector="Border.modalcard RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}"/>
  </Style>

  <!-- Flat-button base: the shared transparent/borderless skin behind every chrome icon/text button
       (statusbtn, segment, findbtn, crumb, chrome-menu, link). Each of those classes keeps only its
       own padding/font/foreground; this grouped selector holds what they all share, so the base lives
       once instead of being repeated in four files. -->
  <Style Selector="Button.statusbtn, Button.segment, Button.findbtn, Button.crumb, Button.chrome-menu, Button.link">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <!-- Premium accent button. FluentAvalonia's built-in `accent` class paints from the generic
       system-accent resources; we drive the primary CTA from the app's own accent tokens instead.
       The background lives on the template's ContentPresenter, so state colours are set through
       /template/ to win over FluentAvalonia's pointerover/pressed setters. -->
  <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.accent">
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
  </Style>
  <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
  </Style>
  <!-- Tactile press feedback. -->
  <Style Selector="Button.accent:pressed">
    <Setter Property="RenderTransform" Value="scale(0.97)" />
  </Style>

  <!-- Recent-file entries (welcome) and outline (TOC) entries share a custom minimal template
       (Border + ContentPresenter). FluentAvalonia's stock Button template flashed its own light
       pointer-over background before our darker overlay settled — the "first light, then dark"
       flicker. Escaping that template makes the hover a single instant overlay on PART_Bg: no FA
       state, no transition, no fade-through, no shimmer. The Button still fires its Command on click. -->
  <Style Selector="Button.recent">
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="PART_Bg" Background="Transparent" Padding="{TemplateBinding Padding}"
                BorderThickness="1" BorderBrush="Transparent"
                CornerRadius="{DynamicResource ControlCornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.recent:pointerover /template/ Border#PART_Bg">
    <Setter Property="Background" Value="{DynamicResource ChromeOverlayBrush}" />
  </Style>
  <Style Selector="Button.recent:pressed /template/ Border#PART_Bg">
    <Setter Property="Background" Value="{DynamicResource ChromeOverlayBrush}" />
  </Style>
  <!-- Keyboard focus ring: the custom template drops FluentAvalonia's focus adorner, so paint the
       (always-present, transparent) 1px border with the accent when focused via the keyboard. -->
  <Style Selector="Button.recent:focus-visible /template/ Border#PART_Bg">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="Button.outline-item">
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="PART_Bg" Background="Transparent" Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="Transparent" CornerRadius="4">
          <ContentPresenter Content="{TemplateBinding Content}"
                            Foreground="{TemplateBinding Foreground}"
                            FontSize="{TemplateBinding FontSize}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="Button.outline-item:pointerover /template/ Border#PART_Bg">
    <Setter Property="Background" Value="{DynamicResource OutlineItemHoverBrush}" />
  </Style>
  <Style Selector="Button.outline-item:pressed /template/ Border#PART_Bg">
    <Setter Property="Background" Value="{DynamicResource OutlineItemHoverBrush}" />
  </Style>
  <Style Selector="Button.outline-item:focus-visible /template/ Border#PART_Bg">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <!-- ☰ title-bar menu flyout: use the app's dark status-bar backing (and its submenus) instead of
       FluentAvalonia's light acrylic, so the dropdown matches the rest of the chrome. -->
  <Style Selector="MenuFlyoutPresenter">
    <Setter Property="Background" Value="{DynamicResource StatusBarBackgroundBrush}" />
  </Style>

  <!-- Hamburger (☰) menu trigger in the title bar: flat and chrome-coloured, with FluentAvalonia's
       built-in pointerover/pressed states (transparent base lets the title strip show through). -->
  <Style Selector="Button.chrome-menu">
    <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}" />
    <Setter Property="Padding" Value="9,4" />
  </Style>

  <!-- Outline-sidebar resize handle: a wide-enough hit area that stays invisible until hovered,
       then shows a faint chrome-coloured hairline (the outline panel already draws the 1px divider). -->
  <Style Selector="GridSplitter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="GridSplitter:pointerover">
    <Setter Property="Background" Value="{DynamicResource ChromeBorderBrush}" />
  </Style>

</Styles>
