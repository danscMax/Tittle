<shared:ModalWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="using:Tittle.Shared"
        xmlns:macros="using:Tittle.Features.Macros"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="420"
        x:Class="Tittle.Features.Macros.MacroManagerWindow"
        x:DataType="macros:MacroManagerViewModel"
        Title="Макросы"
        Width="680" Height="440" MinWidth="580" MinHeight="240">
  <!-- Chrome = ModalWindow + Border.modalcard. -->
  <Border Classes="modalcard" Padding="18">
    <DockPanel LastChildFill="True">
      <TextBlock DockPanel.Dock="Top" Text="Управление макросами" FontSize="16" FontWeight="SemiBold"
                 Margin="0,0,0,4"/>
      <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" FontSize="12" TextWrapping="Wrap"
                 Foreground="{DynamicResource ChromeForegroundMutedBrush}"
                 Text="Первые 9 макросов запускаются с Ctrl+Shift+1…9. Кнопкой «⌨ задать» можно назначить своё сочетание (Ctrl/Alt + …)."/>
      <Button DockPanel.Dock="Bottom" Content="Готово" HorizontalAlignment="Right" Classes="accent"
              Margin="0,12,0,0" AutomationProperties.Name="Закрыть" Click="OnCloseClick"/>
      <TextBlock DockPanel.Dock="Bottom" IsVisible="{Binding IsEmpty}"
                 Text="Пока нет записанных макросов. ☰ Инструменты ▸ Записать макрос."
                 TextWrapping="Wrap" Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="macros:MacroRowViewModel" x:CompileBindings="False">
              <Border Background="{DynamicResource ChromeBackgroundBrush}" CornerRadius="7"
                      BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
                      Padding="8" Margin="0,0,0,8">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                  <TextBox Grid.Column="0" Text="{Binding Name, Mode=TwoWay}" Watermark="Имя макроса"
                           VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                  <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"
                             Foreground="{DynamicResource ChromeForegroundMutedBrush}"
                             Text="{Binding StepCount, StringFormat='{}{0} шаг.'}"/>
                  <NumericUpDown Grid.Column="2" Value="{Binding Count, Mode=TwoWay}" Minimum="1" Maximum="9999"
                                 Width="96" Margin="0,0,8,0" ToolTip.Tip="Сколько раз повторить"
                                 AutomationProperties.Name="Число повторов"/>
                  <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Button Content="{Binding ShortcutLabel}" MinWidth="96"
                            ToolTip.Tip="Назначить горячую клавишу (Ctrl/Alt + …); Esc — отмена"
                            AutomationProperties.Name="Назначить горячую клавишу"
                            Command="{Binding $parent[ItemsControl].DataContext.BeginCaptureCommand}"
                            CommandParameter="{Binding}"/>
                    <Button Content="&#x2715;" Margin="2,0,0,0" IsVisible="{Binding HasShortcut}"
                            ToolTip.Tip="Снять привязку" AutomationProperties.Name="Снять привязку"
                            Command="{Binding $parent[ItemsControl].DataContext.ClearShortcutCommand}"
                            CommandParameter="{Binding}"/>
                  </StackPanel>
                  <Button Grid.Column="4" Content="▶ ×N" Margin="0,0,4,0" ToolTip.Tip="Воспроизвести N раз"
                          Command="{Binding $parent[ItemsControl].DataContext.PlayTimesCommand}"
                          CommandParameter="{Binding}"/>
                  <Button Grid.Column="5" Content="▶▶" Margin="0,0,4,0" ToolTip.Tip="До конца файла"
                          Command="{Binding $parent[ItemsControl].DataContext.PlayToEndCommand}"
                          CommandParameter="{Binding}"/>
                  <Button Grid.Column="6" Content="&#x2715;" ToolTip.Tip="Удалить"
                          Command="{Binding $parent[ItemsControl].DataContext.DeleteCommand}"
                          CommandParameter="{Binding}"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </DockPanel>
  </Border>
</shared:ModalWindow>
