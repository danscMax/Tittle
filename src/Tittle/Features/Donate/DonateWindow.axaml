<shared:ModalWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="using:Tittle.Shared"
        x:Class="Tittle.Features.Donate.DonateWindow"
        Title="Поддержать автора"
        Width="480" SizeToContent="Height" CanResize="False"
        ShowInTaskbar="False" SystemDecorations="None"
        TransparencyLevelHint="Transparent" Background="Transparent"
        WindowStartupLocation="CenterOwner">
  <!-- "Поддержать автора" — premium-but-restrained: an app-icon header badge, an accent "hero" card
       for the card-payment link, and crypto cards (accent edge · fee chip · inset address pill with an
       icon Copy button). Crypto rows come from Core's DonationDirectory; the hero + chrome are static.
       Esc / Закрыть dismisses (Esc from ModalWindow). -->
  <Border Background="{DynamicResource EditorSurfaceBrush}" CornerRadius="14"
          BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
          BoxShadow="{DynamicResource ChromeShadow}" Margin="14">
    <Border.Styles>
      <!-- Hero (card-payment) — a filled accent CTA with a soft accent glow; lightens on hover. -->
      <Style Selector="Button.hero">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16,13"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      </Style>
      <Style Selector="Button.hero /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
      </Style>
      <Style Selector="Button.hero:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
      </Style>

      <!-- Crypto card: subtle surface + hairline, an accent leading edge, generous inner padding. -->
      <Style Selector="Border.cryptocard">
        <Setter Property="Background" Value="{DynamicResource ChromeOverlayBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ClipToBounds" Value="True"/>
      </Style>
      <Style Selector="Border.accentedge">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      </Style>
      <Style Selector="TextBlock.cardtitle">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}"/>
      </Style>
      <!-- Fee/speed as a quiet outlined pill — adds structure without shouting. -->
      <Style Selector="Border.chip">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
      </Style>
      <Style Selector="Border.chip > TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundMutedBrush}"/>
      </Style>
      <!-- Wallet link — accent text, no button chrome. -->
      <Style Selector="Button.link">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
      </Style>
      <Style Selector="Button.link:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource AccentHoverBrush}"/>
      </Style>
      <!-- Address pill — a darker inset slab so the monospace address reads as a copy target. -->
      <Style Selector="Border.addrpill">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="11,8"/>
      </Style>
      <Style Selector="SelectableTextBlock.addr">
        <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}"/>
      </Style>
      <!-- Icon Copy button — quiet outline that flips to an accent check on success. -->
      <Style Selector="Button.copy">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ChromeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Padding" Value="8,7"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
      </Style>
      <Style Selector="Button.copy.done">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
      </Style>
      <Style Selector="Button.copy.done PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
      </Style>
    </Border.Styles>

    <StackPanel>
      <!-- Header: app-icon heart badge + title + intro. -->
      <StackPanel Margin="26,24,26,4" Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="14">
          <Border Width="42" Height="42" CornerRadius="13" VerticalAlignment="Center"
                  Background="{DynamicResource AccentBrush}" BoxShadow="0 4 14 0 #4D5A8DFF">
            <PathIcon Data="{StaticResource IconHeart}" Width="21" Height="21"
                      Foreground="{DynamicResource AccentForegroundBrush}"/>
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="Поддержать автора" FontSize="18.5" FontWeight="SemiBold"
                       Foreground="{DynamicResource ChromeForegroundBrush}"/>
            <TextBlock Text="Спасибо, что пользуетесь Tittle" FontSize="12.5"
                       Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
          </StackPanel>
        </StackPanel>
        <TextBlock Text="Если приложение вам полезно — любая поддержка приветствуется и очень мотивирует. Никакой рекламы и слежки."
                   TextWrapping="Wrap" FontSize="13" LineHeight="19"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
      </StackPanel>

      <!-- Methods: hero card link, then the crypto cards (appended from DonationDirectory). -->
      <StackPanel Margin="26,16,26,6" Spacing="12">
        <!-- Border carries the accent glow (BoxShadow is a Border property, not a Button one). -->
        <Border CornerRadius="12" BoxShadow="0 6 20 0 #3D5A8DFF">
        <Button x:Name="HeroButton" Classes="hero" Click="OnHeroClick"
                ToolTip.Tip="Оплата картой РФ через CloudTips — откроется в браузере">
          <DockPanel>
            <PathIcon DockPanel.Dock="Left" Data="{StaticResource IconCard}" Width="22" Height="22"
                      Margin="0,0,13,0" VerticalAlignment="Center"
                      Foreground="{DynamicResource AccentForegroundBrush}"/>
            <PathIcon DockPanel.Dock="Right" Data="{StaticResource IconExternalLink}" Width="15" Height="15"
                      Opacity="0.85" VerticalAlignment="Center"
                      Foreground="{DynamicResource AccentForegroundBrush}"/>
            <StackPanel Spacing="1" VerticalAlignment="Center">
              <TextBlock Text="Поддержать картой" FontSize="14.5" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentForegroundBrush}"/>
              <TextBlock Text="CloudTips · карты РФ · откроется в браузере" FontSize="12" Opacity="0.82"
                         Foreground="{DynamicResource AccentForegroundBrush}"/>
            </StackPanel>
          </DockPanel>
        </Button>
        </Border>

        <StackPanel x:Name="CryptoPanel" Spacing="12"/>
      </StackPanel>

      <!-- Footer: hairline divider + a quiet close. -->
      <Border BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="0,1,0,0"
              Margin="0,10,0,0" Padding="26,12,26,16">
        <Button Content="Закрыть" HorizontalAlignment="Right" Click="OnCloseClick"/>
      </Border>
    </StackPanel>
  </Border>
</shared:ModalWindow>
