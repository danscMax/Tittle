<shared:ModalWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="using:Tittle.Shared"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="320"
        x:Class="Tittle.Features.Settings.LayoutSettingsWindow"
        x:DataType="shared:LayoutOptions"
        Title="Раскладка"
        Width="400" SizeToContent="Height" CanResize="False"
        ShowInTaskbar="False" SystemDecorations="None"
        TransparencyLevelHint="Transparent" Background="Transparent"
        WindowStartupLocation="CenterOwner">
  <!-- A standalone top-level window (like the command palette): bound to the shared LayoutOptions, so every
       toggle persists and re-renders the chrome live. Stays open (no click-away close) so the user can watch
       the changes; Esc / Готово close it. -->
  <Border Background="{DynamicResource EditorSurfaceBrush}" CornerRadius="10"
          BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
          BoxShadow="{DynamicResource ChromeShadow}" Margin="14" Padding="20">
    <StackPanel Spacing="16">
      <TextBlock Text="Раскладка интерфейса" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource ChromeForegroundBrush}"/>

      <CheckBox IsChecked="{Binding ShowOmnibar, Mode=TwoWay}"
                Foreground="{DynamicResource ChromeForegroundBrush}"
                Content="Омнибар (путь · открыть · палитра)"/>
      <CheckBox IsChecked="{Binding ReadingMode, Mode=TwoWay}"
                Foreground="{DynamicResource ChromeForegroundBrush}"
                Content="Декоративный фон предпросмотра"/>

      <StackPanel Spacing="6">
        <TextBlock Text="Панель инструментов" FontSize="12.5"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
        <RadioButton GroupName="Toolbar" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Контекстная (в режиме «Исходник»)"
                     IsChecked="{Binding ToolbarMode, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Contextual}"/>
        <RadioButton GroupName="Toolbar" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Всегда показывать"
                     IsChecked="{Binding ToolbarMode, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Fixed}"/>
        <RadioButton GroupName="Toolbar" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Выключена"
                     IsChecked="{Binding ToolbarMode, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Off}"/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Ширина колонки чтения" FontSize="12.5"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
        <RadioButton GroupName="ReadingWidth" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Полная"
                     IsChecked="{Binding ReadingWidth, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Full}"/>
        <RadioButton GroupName="ReadingWidth" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Средняя (760 px)"
                     IsChecked="{Binding ReadingWidth, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Comfort}"/>
        <RadioButton GroupName="ReadingWidth" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Узкая (620 px)"
                     IsChecked="{Binding ReadingWidth, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Narrow}"/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Разреженность текста" FontSize="12.5"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
        <RadioButton GroupName="ReadingDensity" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Плотно"
                     IsChecked="{Binding ReadingDensity, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Compact}"/>
        <RadioButton GroupName="ReadingDensity" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Обычно"
                     IsChecked="{Binding ReadingDensity, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Normal}"/>
        <RadioButton GroupName="ReadingDensity" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Просторно"
                     IsChecked="{Binding ReadingDensity, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Relaxed}"/>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Ориентация разделённого вида" FontSize="12.5"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
        <RadioButton GroupName="SplitOrientation" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Горизонтальная (рядом)"
                     IsChecked="{Binding SplitOrientation, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Horizontal}"/>
        <RadioButton GroupName="SplitOrientation" Foreground="{DynamicResource ChromeForegroundBrush}"
                     Content="Вертикальная (друг над другом)"
                     IsChecked="{Binding SplitOrientation, Mode=TwoWay, Converter={x:Static shared:EnumRadioConverter.Instance}, ConverterParameter=Vertical}"/>
      </StackPanel>

      <!-- Diagrams (M12). DataContext is the shared DiagramOptions, assigned in code-behind. -->
      <StackPanel x:Name="DiagramSection" x:DataType="shared:DiagramOptions" Spacing="6">
        <TextBlock Text="Диаграммы" FontSize="12.5"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"
                  Foreground="{DynamicResource ChromeForegroundBrush}"
                  Content="Рендерить диаграммы через Kroki"/>
        <TextBox Text="{Binding KrokiUrl, Mode=TwoWay}" IsEnabled="{Binding Enabled}"
                 Watermark="https://kroki.io" AutomationProperties.Name="Адрес сервера Kroki"/>
        <TextBlock TextWrapping="Wrap" FontSize="11.5"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"
                   Text="Текст диаграммы (```mermaid, ```plantuml, ```dot …) отправляется на указанный сервер. По умолчанию выключено; можно указать свой self-hosted Kroki."/>
      </StackPanel>

      <Button Content="Готово" HorizontalAlignment="Right" Classes="accent"
              AutomationProperties.Name="Закрыть настройки" Click="OnDone"/>
    </StackPanel>
  </Border>
</shared:ModalWindow>
