<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.Styling"
             x:Class="SeriousView.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://SeriousView/Themes/Tokens.axaml" />
                <ResourceInclude Source="avares://SeriousView/Themes/Tabs.axaml" />
                <ResourceInclude Source="avares://SeriousView/Themes/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceInclude x:Key="Light" Source="avares://SeriousView/Themes/Colors/Light.axaml" />
                <ResourceInclude x:Key="Dark" Source="avares://SeriousView/Themes/Colors/Dark.axaml" />
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <!-- Fluent v2 theme (replaces FluentTheme): WinUI controls + system accent. -->
        <fa:FluentAvaloniaTheme PreferSystemTheme="False" PreferUserAccentColor="True" />
        <!-- AvaloniaEdit control theme — required for TextEditor to render; must come AFTER. -->
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <!-- App animations (theme recolor transitions, fade-in). -->
        <StyleInclude Source="avares://SeriousView/Themes/Animations.axaml" />
        <!-- Custom control styles (accent button, recent-item hover) — after FA to override it. -->
        <StyleInclude Source="avares://SeriousView/Themes/Controls.axaml" />
        <!-- Markdown admonition callouts (GitHub alerts). -->
        <StyleInclude Source="avares://SeriousView/Themes/Admonitions.axaml" />
        <!-- Slim, theme-tinted scrollbars. -->
        <StyleInclude Source="avares://SeriousView/Themes/ScrollBars.axaml" />
    </Application.Styles>
</Application>
