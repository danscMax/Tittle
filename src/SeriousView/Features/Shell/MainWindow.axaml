<wnd:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SeriousView.Features.Shell"
        xmlns:controls="using:SeriousView.Features.Viewer"
        xmlns:views="using:SeriousView.Features.Welcome"
        xmlns:conv="using:SeriousView.Shared"
        xmlns:core="using:SeriousView.Core.Abstractions"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:wnd="using:FluentAvalonia.UI.Windowing"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SeriousView.Features.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1100" Height="750"
        Background="{DynamicResource WindowBackgroundBrush}"
        TransparencyLevelHint="None"
        DragDrop.AllowDrop="True">
  <wnd:AppWindow.Styles>
    <!-- Compact flat buttons for the editor controls that now live in the status bar (wrap/numbers/zoom). -->
    <Style Selector="Button.statusbtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="Padding" Value="6,1"/>
      <Setter Property="FontSize" Value="11.5"/>
      <Setter Property="Foreground" Value="{DynamicResource StatusBarForegroundBrush}"/>
    </Style>
  </wnd:AppWindow.Styles>
  <!-- AppWindow draws our content into the title-bar area (ExtendsContentIntoTitleBar, set in
       code-behind). The single top strip = brand + tab strip + buttons, painted with the
       semi-transparent ChromeOverlayBrush so it picks up the app colour AND lets the OS
       backdrop (Mica/Acrylic) show through. System min/max/close buttons are drawn on top at
       the right; the empty Col3 reserves room for them (TitleBar.RightInset). The editor stays
       solid (EditorSurfaceBrush) for readability; solid fallback in code-behind when no blur. -->
  <DockPanel LastChildFill="True">

    <!-- Title strip wrapped in a Border so it casts a soft shadow onto the body below
         (ZIndex keeps the shadow above the editor/welcome content). -->
    <Border DockPanel.Dock="Top" ZIndex="1" BoxShadow="{DynamicResource ChromeShadow}">
    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
          Background="{DynamicResource ChromeOverlayBrush}" MinHeight="40">
      <!-- ☰ menu — the etalon default (MenuPlacement.Hidden). Replaces the "SeriousView" wordmark
           (which crowded the tabs) and gathers File/View commands. First real consumer of Layout:
           shown only for the Hidden placement (Bar / TitleBar presets arrive with Settings → Layout).
           AllowInteractionInTitleBar so the click opens the flyout instead of dragging the window.
           Standard Avalonia MenuFlyout/MenuItem — FluentAvalonia themes them to match the chrome. -->
      <Button Grid.Column="0" AutomationProperties.AutomationId="MenuButton" ToolTip.Tip="Меню"
              Classes="chrome-menu" Margin="6,0,2,0" VerticalAlignment="Center"
              wnd:AppWindow.AllowInteractionInTitleBar="True"
              IsVisible="{Binding Layout.MenuPlacement, Converter={x:Static conv:EnumToBoolConverter.Instance}, ConverterParameter=Hidden}">
        <TextBlock Text="&#x2630;" FontSize="16"/>
        <Button.Flyout>
          <MenuFlyout Placement="BottomEdgeAlignedLeft">
            <MenuItem Header="Файл">
              <MenuItem Header="Открыть…" InputGesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
              <MenuItem Header="Открыть пример" Command="{Binding OpenSampleCommand}"/>
              <MenuItem Header="Недавние" IsEnabled="{Binding HasRecent}" ItemsSource="{Binding RecentItems}">
                <MenuItem.ItemContainerTheme>
                  <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}"
                                x:DataType="vm:RecentFileItem">
                    <Setter Property="Header" Value="{Binding Name}"/>
                    <Setter Property="Command" Value="{Binding OpenCommand}"/>
                    <Setter Property="ToolTip.Tip" Value="{Binding Path}"/>
                  </ControlTheme>
                </MenuItem.ItemContainerTheme>
              </MenuItem>
              <Separator/>
              <MenuItem Header="Закрыть вкладку" InputGesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}"/>
            </MenuItem>
            <MenuItem Header="Вид">
              <MenuItem Header="Тема">
                <MenuItem Header="Тёмная" ToggleType="Radio" GroupName="Theme"
                          Command="{Binding SetThemeCommand}" CommandParameter="{x:Static core:ThemeMode.Dark}"
                          IsChecked="{Binding CurrentTheme, Mode=OneWay, Converter={x:Static conv:EnumToBoolConverter.Instance}, ConverterParameter=Dark}"/>
                <MenuItem Header="Светлая" ToggleType="Radio" GroupName="Theme"
                          Command="{Binding SetThemeCommand}" CommandParameter="{x:Static core:ThemeMode.Light}"
                          IsChecked="{Binding CurrentTheme, Mode=OneWay, Converter={x:Static conv:EnumToBoolConverter.Instance}, ConverterParameter=Light}"/>
                <MenuItem Header="Авто" ToggleType="Radio" GroupName="Theme"
                          Command="{Binding SetThemeCommand}" CommandParameter="{x:Static core:ThemeMode.Auto}"
                          IsChecked="{Binding CurrentTheme, Mode=OneWay, Converter={x:Static conv:EnumToBoolConverter.Instance}, ConverterParameter=Auto}"/>
              </MenuItem>
              <Separator/>
              <MenuItem Header="Перенос строк" InputGesture="Alt+Z" ToggleType="CheckBox"
                        IsChecked="{Binding Editor.WordWrap, Mode=TwoWay}"/>
              <MenuItem Header="Номера строк" InputGesture="Ctrl+L" ToggleType="CheckBox"
                        IsChecked="{Binding Editor.ShowLineNumbers, Mode=TwoWay}"/>
              <Separator/>
              <MenuItem Header="Перейти к строке…" InputGesture="Ctrl+G" Command="{Binding OpenGoToLineCommand}"/>
            </MenuItem>
          </MenuFlyout>
        </Button.Flyout>
      </Button>

      <!-- Tab strip lives in the title bar; AllowInteractionInTitleBar so clicks select tabs
           instead of dragging the window. Bottom-aligned so the accent line meets the body. -->
      <ListBox Grid.Column="1" wnd:AppWindow.AllowInteractionInTitleBar="True"
               IsVisible="{Binding HasTabs}"
               ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}"
               ItemContainerTheme="{StaticResource VsCodeTab}"
               Background="Transparent" BorderThickness="0" Padding="0"
               VerticalAlignment="Bottom"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Disabled">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:DocumentTabViewModel">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <ui:SymbolIcon FontSize="15" VerticalAlignment="Center"
                             Symbol="{Binding GrammarExtension, Converter={x:Static conv:ExtensionToSymbolConverter.Instance}}"/>
              <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                  VerticalAlignment="Center" Margin="10,0"
                  wnd:AppWindow.AllowInteractionInTitleBar="True">
        <!-- Per-document quick toggles kept next to the tabs (etalon ViewTogglePlacement = Tabs).
             Open / Theme now live in the ☰ menu; wrap / numbers / zoom in the status bar. -->
        <!-- Outline (TOC) sidebar toggle — shown only for markdown tabs. -->
        <Button AutomationProperties.AutomationId="OutlineButton" ToolTip.Tip="Оглавление"
                IsVisible="{Binding SelectedTab.IsMarkdown}"
                Command="{Binding ToggleOutlineCommand}" Padding="8,3">
          <ui:SymbolIcon Symbol="List" FontSize="16"/>
        </Button>
        <!-- Preview/source toggle — shown only for markdown tabs. -->
        <Button Content="{Binding SelectedTab.ViewModeLabel}" AutomationProperties.AutomationId="ViewModeButton"
                IsVisible="{Binding SelectedTab.IsMarkdown}"
                Command="{Binding SelectedTab.ToggleViewModeCommand}" Padding="10,3" MinWidth="104"/>
      </StackPanel>

      <!-- Reserve room for the system min/max/close buttons. Width is set in code-behind from
           TitleBar.RightInset once the native title bar is initialised (the property does not
           notify, so an XAML binding would stay at its initial 0). -->
      <Border Grid.Column="3" x:Name="CaptionReserve"/>
    </Grid>
    </Border>

    <!-- Segmented status bar: left = messages (idle / read errors), right = active-tab metrics
         (lines · chars · language), divided by a thin separator. -->
    <Border DockPanel.Dock="Bottom" Classes="chrome"
            Background="{DynamicResource StatusBarBackgroundBrush}" Padding="{DynamicResource StatusBarPadding}">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedTab.StatusText}"
                   Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11.5"
                   Opacity="0.92" VerticalAlignment="Center"/>
        <!-- Caret position — only meaningful (and shown) while the source editor is visible. -->
        <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedTab.CaretText}"
                   IsVisible="{Binding SelectedTab.ShowSource}" Margin="0,0,12,0"
                   Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11.5"
                   Opacity="0.92" VerticalAlignment="Center"/>
        <!-- Editor controls (wrap · numbers · zoom) — status bar, source view only (moved from the
             title bar). Same commands as the keyboard shortcuts and the shared EditorOptions. -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" Margin="0,0,10,0"
                    VerticalAlignment="Center" IsVisible="{Binding SelectedTab.ShowSource}">
          <Button Command="{Binding ToggleWordWrapCommand}" ToolTip.Tip="Перенос строк (Alt+Z)"
                  Content="↵" Classes="statusbtn"/>
          <Button Command="{Binding ToggleLineNumbersCommand}" ToolTip.Tip="Номера строк (Ctrl+L)"
                  Content="#" Classes="statusbtn"/>
          <Button Command="{Binding ZoomOutCommand}" ToolTip.Tip="Меньше (Ctrl+−)"
                  Content="A−" Classes="statusbtn"/>
          <Button Command="{Binding ZoomResetCommand}" ToolTip.Tip="Сбросить масштаб (Ctrl+0)"
                  Content="{Binding Editor.FontSize}" Classes="statusbtn"/>
          <Button Command="{Binding ZoomInCommand}" ToolTip.Tip="Больше (Ctrl++)"
                  Content="A+" Classes="statusbtn"/>
        </StackPanel>
        <Border DockPanel.Dock="Right" Width="1" Margin="10,1" IsVisible="{Binding HasTabs}"
                Background="{DynamicResource StatusBarForegroundBrush}" Opacity="0.3"/>
        <!-- Left segment: status messages, replaced by the go-to-line input (Ctrl+G) while open.
             Lives in the status bar (chrome) rather than over the editor, where an overlay won't
             repaint over AvaloniaEdit's GPU surface. -->
        <Panel>
          <TextBlock Text="{Binding StatusText}" IsVisible="{Binding !SelectedTab.IsGoToLineOpen}"
                     Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11.5"
                     VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                      IsVisible="{Binding SelectedTab.IsGoToLineOpen}">
            <TextBlock Text="Перейти к строке:" VerticalAlignment="Center"
                       Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11.5"/>
            <TextBox x:Name="GoToLineBox" Width="72" Height="22" Padding="6,1" FontSize="11.5"
                     Text="{Binding SelectedTab.GoToLineText}" VerticalAlignment="Center"/>
          </StackPanel>
        </Panel>
      </DockPanel>
    </Border>

    <!-- Outline sidebar (col 0, collapses to 0 when hidden) + document body (col 1). -->
    <Grid ColumnDefinitions="Auto,*">
      <controls:OutlinePanel Grid.Column="0" IsVisible="{Binding IsOutlinePaneVisible}"/>

      <Panel Grid.Column="1">
        <!-- Welcome view shown when no tabs are open. -->
        <views:WelcomeView IsVisible="{Binding !HasTabs}"/>
        <ContentControl IsVisible="{Binding HasTabs}" Content="{Binding SelectedTab}">
          <ContentControl.ContentTemplate>
            <DataTemplate x:DataType="vm:DocumentTabViewModel">
              <controls:DocumentView/>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </Panel>
    </Grid>

  </DockPanel>
</wnd:AppWindow>
