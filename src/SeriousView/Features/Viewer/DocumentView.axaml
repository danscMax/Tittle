<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ae="using:AvaloniaEdit"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
             xmlns:vm="using:SeriousView.Features.Shell"
             xmlns:viewer="using:SeriousView.Features.Viewer"
             x:Class="SeriousView.Features.Viewer.DocumentView"
             x:DataType="vm:DocumentTabViewModel">
  <!-- One tab's body: source editor, rendered preview, and a notice overlay occupy the same
       area, toggled by IsVisible (ShowSource / ShowPreview / ShowNotice are mutually exclusive). -->
  <Panel>
    <!-- Source view: any non-markdown file, or a markdown file toggled to Source. -->
    <ae:TextEditor x:Name="Source"
                   IsVisible="{Binding ShowSource}"
                   viewer:EditorBehavior.Text="{Binding DocumentText}"
                   viewer:EditorBehavior.GrammarExtension="{Binding GrammarExtension}"
                   viewer:EditorBehavior.SuppressHighlight="{Binding HighlightSuppressed}"
                   Background="{DynamicResource EditorSurfaceBrush}"
                   FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                   FontSize="{Binding Editor.FontSize, FallbackValue=14}"
                   ShowLineNumbers="{Binding Editor.ShowLineNumbers, FallbackValue=True}"
                   WordWrap="{Binding Editor.WordWrap, FallbackValue=False}"
                   HorizontalScrollBarVisibility="Auto"
                   VerticalScrollBarVisibility="Auto"/>

    <!-- Rendered markdown preview, on a solid editor surface (MarkdownScrollViewer
         itself has no Background). MarkdownStyleName is deliberately NOT set: the
         auto-detected FluentAvalonia style is theme-variant aware (follows Light/Dark);
         GithubLike/Standard use fixed colours and render invisible text in dark mode.
         The hyperlink command is hardened in code-behind. -->
    <Border IsVisible="{Binding ShowPreview}" Background="{DynamicResource EditorSurfaceBrush}">
      <md:MarkdownScrollViewer x:Name="Preview"
                               Markdown="{Binding PreviewMarkdown}"
                               AssetPathRoot="{Binding AssetPathRoot}"
                               SelectionEnabled="True"/>
    </Border>

    <!-- Notice overlay: binary / too-large / empty files (no editor, no preview).
         Text-only (no SymbolIcon) so it renders without the FluentAvalonia Symbols font. -->
    <Border IsVisible="{Binding ShowNotice}" Background="{DynamicResource EditorSurfaceBrush}">
      <TextBlock Text="{Binding NoticeText}" TextWrapping="Wrap" TextAlignment="Center"
                 MaxWidth="420" FontSize="15"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
    </Border>
  </Panel>
</UserControl>
