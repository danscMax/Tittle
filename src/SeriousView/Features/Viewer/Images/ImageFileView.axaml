<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SeriousView.Features.Shell"
             x:Class="SeriousView.Features.Viewer.Images.ImageFileView"
             x:DataType="vm:DocumentTabViewModel">
  <!-- Root background = a tiled checkerboard (built in code-behind) so transparency reads. The image
       is shown at its natural pixels (Stretch=None); a LayoutTransform applies rotation × the
       effective scale (fit-to-window or a free/100% zoom), the ScrollViewer pans when zoomed. -->
  <Panel x:Name="Root">
    <ScrollViewer x:Name="ImageScroll" Background="Transparent" Padding="16"
                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  IsVisible="{Binding ImageSource, Converter={x:Static ObjectConverters.IsNotNull}}">
      <Panel x:Name="CenterPanel" HorizontalAlignment="Stretch" Background="Transparent">
        <LayoutTransformControl x:Name="Xform" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Image x:Name="Img" Source="{Binding ImageSource}" Stretch="None"/>
        </LayoutTransformControl>
      </Panel>
    </ScrollViewer>

    <!-- Fallback: the file couldn't be decoded. Offer the OS viewer. -->
    <Border IsVisible="{Binding ImageSource, Converter={x:Static ObjectConverters.IsNull}}"
            Background="{DynamicResource EditorSurfaceBrush}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="440">
        <TextBlock Text="Не удалось открыть изображение"
                   TextWrapping="Wrap" TextAlignment="Center" FontSize="15"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}"/>
        <Button Content="Открыть во внешнем приложении" HorizontalAlignment="Center"
                Command="{Binding OpenExternallyCommand}"
                AutomationProperties.Name="Открыть во внешнем приложении"/>
      </StackPanel>
    </Border>
  </Panel>
</UserControl>
