<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:CompileBindings="False">

  <!-- Flat, compact VS Code-style document tab. Applied to the tab-strip ListBox via
       ItemContainerTheme; replaces FluentAvalonia's large default TabItem look.
       The tab header comes from ListBox.ItemTemplate (DocumentTabViewModel.Header);
       this theme adds the hover/selected chrome, the close button and the accent
       underline shown on the active tab. -->
  <ControlTheme x:Key="VsCodeTab" TargetType="ListBoxItem">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundMutedBrush}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="PART_Bg" Background="{TemplateBinding Background}"
                BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="0,0,1,0">
          <Border.Transitions>
            <!-- Smooth hover/select recolor (= DurFast token). -->
            <Transitions>
              <BrushTransition Property="Background" Duration="0:0:0.12" />
            </Transitions>
          </Border.Transitions>
          <Grid ColumnDefinitions="*,Auto" Height="34" MinWidth="92">
            <ContentPresenter Grid.Column="0"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              VerticalAlignment="Center" Margin="12,0,4,0" />
            <!-- Close (✕): hidden until the tab is hovered or selected. -->
            <Button x:Name="PART_Close" Grid.Column="1" Content="&#x2715;"
                    FontSize="10" Width="18" Height="18" Padding="0" Margin="2,0,8,0"
                    VerticalAlignment="Center" Opacity="0"
                    AutomationProperties.AutomationId="CloseTabButton"
                    Background="Transparent" BorderThickness="0"
                    Command="{Binding $parent[ListBox].DataContext.CloseTabCommand}"
                    CommandParameter="{Binding}">
              <Button.Transitions>
                <!-- Fade the ✕ in/out on hover (= DurFast token). -->
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
              </Button.Transitions>
            </Button>
            <!-- Thin accent line under the active tab. -->
            <Border x:Name="PART_Accent" Grid.ColumnSpan="2" Height="2"
                    VerticalAlignment="Bottom" IsVisible="False"
                    Background="{DynamicResource AccentBrush}" />
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#PART_Bg">
      <Setter Property="Background" Value="{DynamicResource ChromeOverlayBrush}" />
    </Style>
    <Style Selector="^:pointerover /template/ Button#PART_Close">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="^:selected">
      <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}" />
    </Style>
    <Style Selector="^:selected /template/ Border#PART_Bg">
      <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    </Style>
    <Style Selector="^:selected /template/ Border#PART_Accent">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:selected /template/ Button#PART_Close">
      <Setter Property="Opacity" Value="1" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
