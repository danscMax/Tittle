<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Dark theme — premium palette ============
         Referenced via {DynamicResource}; swaps instantly on theme change.
         *OverlayBrush = semi-transparent chrome (lets Mica/Acrylic show through, C8).
         EditorSurfaceBrush = solid backing under the editor (keeps code readable). -->

    <!-- Base surfaces -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#15151A" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#1B1B22" />

    <!-- Chrome (subtle vertical gradient for depth) -->
    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#2B2B36" Offset="0" />
        <GradientStop Color="#212129" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#26262F" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#393944" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#E7E7EF" />
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#9A9AA8" />

    <!-- Subtle hover overlay for outline (TOC) items (reads on the chrome sidebar). -->
    <SolidColorBrush x:Key="OutlineItemHoverBrush" Color="#FFFFFF" Opacity="0.07" />

    <!-- Reader / welcome ambient glow (shared by the reading column and the welcome screen). -->
    <RadialGradientBrush x:Key="ReaderGlowABrush" Center="28%,22%" GradientOrigin="28%,22%" RadiusX="55%" RadiusY="55%">
        <GradientStop Color="#552D6CF6" Offset="0" />
        <GradientStop Color="#002D6CF6" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="ReaderGlowBBrush" Center="78%,82%" GradientOrigin="78%,82%" RadiusX="55%" RadiusY="55%">
        <GradientStop Color="#4422D3C5" Offset="0" />
        <GradientStop Color="#0022D3C5" Offset="1" />
    </RadialGradientBrush>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#5A8DFF" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#74A0FF" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />

    <!-- Status bar — muted chrome tone (sits with the title bar, not a screaming accent). -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#20202A" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#B7B7C5" />

    <!-- Admonitions / GitHub alerts (dark): accent stripe (full colour) + subtle tint. -->
    <SolidColorBrush x:Key="AdmonitionNoteBrush" Color="#4493F8" />
    <SolidColorBrush x:Key="AdmonitionNoteBgBrush" Color="#4493F8" Opacity="0.12" />
    <SolidColorBrush x:Key="AdmonitionTipBrush" Color="#3FB950" />
    <SolidColorBrush x:Key="AdmonitionTipBgBrush" Color="#3FB950" Opacity="0.12" />
    <SolidColorBrush x:Key="AdmonitionImportantBrush" Color="#AB7DF8" />
    <SolidColorBrush x:Key="AdmonitionImportantBgBrush" Color="#AB7DF8" Opacity="0.12" />
    <SolidColorBrush x:Key="AdmonitionWarningBrush" Color="#D29922" />
    <SolidColorBrush x:Key="AdmonitionWarningBgBrush" Color="#D29922" Opacity="0.12" />
    <SolidColorBrush x:Key="AdmonitionCautionBrush" Color="#F85149" />
    <SolidColorBrush x:Key="AdmonitionCautionBgBrush" Color="#F85149" Opacity="0.12" />

</ResourceDictionary>
