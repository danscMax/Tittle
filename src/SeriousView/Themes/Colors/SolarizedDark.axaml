<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Solarized Dark (ported) ============
         Ethan Schoonover's deep teal base. Inherits the Dark variant — only surface/chrome/accent
         tokens here; admonitions, cv-* decorations etc. fall back to Dark.axaml. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#002B36" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#073642" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#093F4C" />

    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#0A4250" Offset="0" />
        <GradientStop Color="#073642" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#073642" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#0E4954" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#B6C2C2" />
    <Color x:Key="ChromeForegroundColor">#B6C2C2</Color>
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#839496" />

    <SolidColorBrush x:Key="AccentBrush" Color="#B58900" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#D0A020" />

    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#04323D" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#839496" />

</ResourceDictionary>
