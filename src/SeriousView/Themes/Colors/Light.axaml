<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Light theme — premium palette (same keys as Dark.axaml) ============ -->

    <!-- Base surfaces -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F7F7FB" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#FFFFFF" />

    <!-- Chrome (subtle vertical gradient for depth) -->
    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#EDEDF3" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#F4F4F9" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#D9D9E2" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#1B1B24" />
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#6B6B78" />

    <!-- Subtle hover overlay for outline (TOC) items (reads on the chrome sidebar). -->
    <SolidColorBrush x:Key="OutlineItemHoverBrush" Color="#000000" Opacity="0.06" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2D6CF6" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1F5AE8" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />

    <!-- Status bar — muted chrome tone (sits with the title bar, not a screaming accent). -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#ECECF2" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#54546A" />

    <!-- Admonitions / GitHub alerts (light): accent stripe (full colour) + subtle tint. -->
    <SolidColorBrush x:Key="AdmonitionNoteBrush" Color="#0969DA" />
    <SolidColorBrush x:Key="AdmonitionNoteBgBrush" Color="#0969DA" Opacity="0.10" />
    <SolidColorBrush x:Key="AdmonitionTipBrush" Color="#1A7F37" />
    <SolidColorBrush x:Key="AdmonitionTipBgBrush" Color="#1A7F37" Opacity="0.10" />
    <SolidColorBrush x:Key="AdmonitionImportantBrush" Color="#8250DF" />
    <SolidColorBrush x:Key="AdmonitionImportantBgBrush" Color="#8250DF" Opacity="0.10" />
    <SolidColorBrush x:Key="AdmonitionWarningBrush" Color="#9A6700" />
    <SolidColorBrush x:Key="AdmonitionWarningBgBrush" Color="#9A6700" Opacity="0.10" />
    <SolidColorBrush x:Key="AdmonitionCautionBrush" Color="#CF222E" />
    <SolidColorBrush x:Key="AdmonitionCautionBgBrush" Color="#CF222E" Opacity="0.10" />

</ResourceDictionary>
