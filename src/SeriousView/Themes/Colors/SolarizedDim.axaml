<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Solarized Dim (ported) ============
         A muted mid-tone between Solarized Light and Dark. Inherits the Dark variant — only
         surface/chrome/accent tokens here; the rest falls back to Dark.axaml. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1C2A2F" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#16242A" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#1E3038" />

    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#243840" Offset="0" />
        <GradientStop Color="#1C2A2F" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#16242A" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#2A3D44" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#AFBDBD" />
    <Color x:Key="ChromeForegroundColor">#AFBDBD</Color>
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#8C9B9B" />

    <SolidColorBrush x:Key="AccentBrush" Color="#268BD2" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#4AA8E0" />

    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#142026" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#829292" />

</ResourceDictionary>
