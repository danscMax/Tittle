<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Dracula (ported) ============
         The classic purple-on-charcoal palette. Inherits the Dark variant — only surface/chrome/
         accent tokens here; admonitions, cv-* decorations etc. fall back to Dark.axaml. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#282A36" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#21222C" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#2D2F3D" />

    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#343746" Offset="0" />
        <GradientStop Color="#282A36" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#21222C" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#44475A" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#F8F8F2" />
    <Color x:Key="ChromeForegroundColor">#F8F8F2</Color>
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#9098C0" />

    <SolidColorBrush x:Key="AccentBrush" Color="#BD93F9" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#D0B0FF" />

    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#1E1F28" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#9FA6C4" />

</ResourceDictionary>
