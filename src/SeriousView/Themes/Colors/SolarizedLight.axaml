<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Solarized Light (ported, light family) ============
         Cream base, blue accent. Inherits the Light variant — only surface/chrome/accent tokens
         here; admonitions, cv-* decorations etc. fall back to Light.axaml. -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FDF6E3" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#FFFDF5" />
    <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#EEE8D5" />

    <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#FBF8EC" Offset="0" />
        <GradientStop Color="#EEE8D5" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ChromeOverlayBrush" Color="#EEE8D5" Opacity="0.72" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#D5CEB2" />
    <SolidColorBrush x:Key="ChromeForegroundBrush" Color="#586E75" />
    <Color x:Key="ChromeForegroundColor">#586E75</Color>
    <SolidColorBrush x:Key="ChromeForegroundMutedBrush" Color="#657B83" />

    <SolidColorBrush x:Key="AccentBrush" Color="#268BD2" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2076B7" />

    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#EAE3CE" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#586E75" />

</ResourceDictionary>
