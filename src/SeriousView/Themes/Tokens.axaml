<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Theme-agnostic design tokens (color tokens live in Themes/Colors/*.axaml). -->

    <!-- Typography / spacing -->
    <x:Double x:Key="ChromeFontSize">12.5</x:Double>
    <Thickness x:Key="ChromePadding">14,8</Thickness>
    <Thickness x:Key="StatusBarPadding">14,4</Thickness>

    <!-- Radii -->
    <CornerRadius x:Key="PanelCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>

    <!-- Elevation (offsetX offsetY blur spread color) -->
    <BoxShadows x:Key="ChromeShadow">0 2 14 0 #45000000</BoxShadows>

    <!-- Animation durations -->
    <sys:TimeSpan x:Key="DurFast">0:0:0.12</sys:TimeSpan>
    <sys:TimeSpan x:Key="DurBase">0:0:0.20</sys:TimeSpan>
    <sys:TimeSpan x:Key="DurSlow">0:0:0.30</sys:TimeSpan>

</ResourceDictionary>
