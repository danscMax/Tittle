<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Premium accent button. FluentAvalonia's built-in `accent` class paints from the generic
       system-accent resources; we drive the primary CTA from the app's own accent tokens instead.
       The background lives on the template's ContentPresenter, so state colours are set through
       /template/ to win over FluentAvalonia's pointerover/pressed setters. -->
  <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.accent">
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
  </Style>
  <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
  </Style>
  <!-- Tactile press feedback. -->
  <Style Selector="Button.accent:pressed">
    <Setter Property="RenderTransform" Value="scale(0.97)" />
  </Style>

  <!-- Recent-file entries on the welcome screen: rounded hover highlight so they read as
       clickable (they are otherwise transparent and borderless). -->
  <Style Selector="Button.recent /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.recent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ChromeOverlayBrush}" />
  </Style>

  <!-- Outline (TOC) entries: subtle overlay hover that reads on the chrome-coloured sidebar
       (ChromeOverlayBrush would be invisible there). -->
  <Style Selector="Button.outline-item /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.1" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button.outline-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource OutlineItemHoverBrush}" />
  </Style>

  <!-- Hamburger (☰) menu trigger in the title bar: flat and chrome-coloured, with FluentAvalonia's
       built-in pointerover/pressed states (transparent base lets the title strip show through). -->
  <Style Selector="Button.chrome-menu">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource ChromeForegroundBrush}" />
    <Setter Property="Padding" Value="9,4" />
  </Style>

</Styles>
