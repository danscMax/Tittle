<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Smooth recolor of chrome surfaces when the theme changes. -->
    <Style Selector="Border.chrome">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.20" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.20" />
            </Transitions>
        </Setter>
    </Style>

    <!-- Fade-in for empty-state / welcome content. -->
    <Style Selector="TextBlock.fade-in">
        <Style.Animations>
            <Animation Duration="0:0:0.28" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0.55" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Entrance for the welcome content: gentle fade-in on launch. (Avalonia KeyFrame
         animation has no animator for the composite RenderTransform, so the slide variant
         would need a TranslateTransform target; a clean fade is enough and crash-free.) -->
    <Style Selector="StackPanel.welcome-enter">
        <Style.Animations>
            <Animation Duration="0:0:0.34" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
