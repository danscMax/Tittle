<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:vm="using:SeriousView.ViewModels"
        xmlns:controls="using:SeriousView.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SeriousView.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1100" Height="750"
        Background="{DynamicResource WindowBackgroundBrush}">
  <DockPanel LastChildFill="True">

    <Border DockPanel.Dock="Top" Background="{DynamicResource ChromeBackgroundBrush}" Padding="12,7"
            BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Content="Тема" AutomationProperties.AutomationId="ThemeButton"
                  Command="{Binding ToggleThemeCommand}" Padding="10,3"/>
          <Button Content="Открыть…" AutomationProperties.AutomationId="OpenButton"
                  Command="{Binding OpenFileCommand}" Padding="10,3"/>
        </StackPanel>
        <TextBlock Text="SeriousView" FontWeight="SemiBold"
                   Foreground="{DynamicResource ChromeForegroundBrush}"
                   FontSize="12.5" VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBackgroundBrush}" Padding="12,3">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11.5"/>
    </Border>

    <Panel>
      <!-- Placeholder shown when no tabs are open (replaced by a richer Welcome view in a later step). -->
      <TextBlock Text="Нет открытых файлов" IsVisible="{Binding !HasTabs}"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="{DynamicResource ChromeForegroundBrush}" Opacity="0.55" FontSize="15"/>
      <TabControl IsVisible="{Binding HasTabs}"
                  ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" Padding="0">
      <TabControl.ItemTemplate>
        <DataTemplate x:DataType="vm:DocumentTabViewModel">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
            <Button Content="✕" FontSize="10" Padding="5,1"
                    AutomationProperties.AutomationId="CloseTabButton"
                    Background="Transparent" BorderThickness="0"
                    Command="{Binding $parent[TabControl].((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                    CommandParameter="{Binding}"/>
          </StackPanel>
        </DataTemplate>
      </TabControl.ItemTemplate>
      <TabControl.ContentTemplate>
        <DataTemplate x:DataType="vm:DocumentTabViewModel">
          <ae:TextEditor controls:EditorBehavior.Text="{Binding Content}"
                         controls:EditorBehavior.GrammarExtension="{Binding GrammarExtension}"
                         FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                         FontSize="14"
                         ShowLineNumbers="True"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"/>
        </DataTemplate>
      </TabControl.ContentTemplate>
      </TabControl>
    </Panel>

  </DockPanel>
</Window>
