<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:vm="using:SeriousView.ViewModels"
        xmlns:controls="using:SeriousView.Controls"
        xmlns:views="using:SeriousView.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SeriousView.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1100" Height="750"
        Background="Transparent"
        TransparencyLevelHint="Mica, AcrylicBlur, Blur"
        DragDrop.AllowDrop="True">
  <!-- Background=Transparent + Mica: the OS draws the blurred backdrop; chrome uses
       semi-transparent ChromeOverlayBrush so it shows through, the editor stays solid
       (EditorSurfaceBrush) for readability. Solid fallback in code-behind when the OS
       reports no transparency. -->
  <DockPanel LastChildFill="True">

    <Border DockPanel.Dock="Top" Classes="chrome"
            Background="{DynamicResource ChromeOverlayBrush}" Padding="{DynamicResource ChromePadding}"
            BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
          <Button Content="{Binding ThemeModeLabel}" AutomationProperties.AutomationId="ThemeButton"
                  Command="{Binding ToggleThemeCommand}" Padding="10,3" MinWidth="84"/>
          <Button Content="Открыть…" AutomationProperties.AutomationId="OpenButton"
                  Command="{Binding OpenFileCommand}" Padding="10,3"/>
        </StackPanel>
        <TextBlock Text="SeriousView" FontWeight="SemiBold"
                   Foreground="{DynamicResource ChromeForegroundBrush}"
                   FontSize="12.5" VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Classes="chrome"
            Background="{DynamicResource StatusBarBackgroundBrush}" Padding="{DynamicResource StatusBarPadding}">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="{DynamicResource StatusBarForegroundBrush}" FontSize="11.5"/>
    </Border>

    <Panel>
      <!-- Welcome view shown when no tabs are open. -->
      <views:WelcomeView IsVisible="{Binding !HasTabs}"/>
      <TabControl IsVisible="{Binding HasTabs}"
                  ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" Padding="0">
        <TabControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DocumentTabViewModel">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
              <Button Content="✕" FontSize="10" Padding="5,1"
                      AutomationProperties.AutomationId="CloseTabButton"
                      Background="Transparent" BorderThickness="0"
                      Command="{Binding $parent[TabControl].((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                      CommandParameter="{Binding}"/>
            </StackPanel>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate x:DataType="vm:DocumentTabViewModel">
            <ae:TextEditor controls:EditorBehavior.Text="{Binding DocumentText}"
                           controls:EditorBehavior.GrammarExtension="{Binding GrammarExtension}"
                           Background="{DynamicResource EditorSurfaceBrush}"
                           FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                           FontSize="14"
                           ShowLineNumbers="True"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"/>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>
    </Panel>

  </DockPanel>
</Window>
