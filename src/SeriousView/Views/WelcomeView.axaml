<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SeriousView.ViewModels"
             x:Class="SeriousView.Views.WelcomeView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="14" MaxWidth="460" Margin="24,40">

      <TextBlock Text="SeriousView" FontSize="34" FontWeight="Bold"
                 Foreground="{DynamicResource ChromeForegroundBrush}" HorizontalAlignment="Center"/>
      <TextBlock Text="Нативный просмотрщик markdown и кода"
                 Foreground="{DynamicResource ChromeForegroundMutedBrush}"
                 FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8"/>

      <Button Content="Открыть файл…" Command="{Binding OpenFileCommand}"
              Classes="accent" HorizontalAlignment="Center" Padding="18,9"/>

      <StackPanel IsVisible="{Binding HasRecent}" Spacing="2" Margin="0,18,0,0">
        <TextBlock Text="Недавние" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}" Margin="6,0,0,4"/>
        <ItemsControl ItemsSource="{Binding RecentFiles}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="x:String">
              <Button Content="{Binding}" ToolTip.Tip="{Binding}"
                      Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenRecentCommand}"
                      CommandParameter="{Binding}"
                      Background="Transparent" BorderThickness="0"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Padding="8,5"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
