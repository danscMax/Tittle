<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SeriousView.ViewModels"
             x:Class="SeriousView.Views.WelcomeView"
             x:DataType="vm:MainWindowViewModel">
  <Panel>
    <!-- Acrylic backdrop: the blurred desktop shows through behind the welcome content,
         giving the empty state a premium frosted-glass look (tint follows the theme). -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                     TintColor="{DynamicResource AcrylicTintColor}"
                                     TintOpacity="0.5" MaterialOpacity="0.5" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <!-- Soft accent glows for depth — visible regardless of what is behind the window,
         so the empty state always reads as premium (the acrylic adds the desktop blur). -->
    <Border IsHitTestVisible="False">
      <Border.Background>
        <RadialGradientBrush Center="28%,22%" GradientOrigin="28%,22%" RadiusX="55%" RadiusY="55%">
          <GradientStop Color="#552D6CF6" Offset="0" />
          <GradientStop Color="#002D6CF6" Offset="1" />
        </RadialGradientBrush>
      </Border.Background>
    </Border>
    <Border IsHitTestVisible="False">
      <Border.Background>
        <RadialGradientBrush Center="78%,82%" GradientOrigin="78%,82%" RadiusX="55%" RadiusY="55%">
          <GradientStop Color="#4422D3C5" Offset="0" />
          <GradientStop Color="#0022D3C5" Offset="1" />
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <ScrollViewer>
    <StackPanel Classes="welcome-enter"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="14" MaxWidth="460" Margin="24,40">

      <TextBlock Text="SeriousView" FontSize="34" FontWeight="Bold"
                 Foreground="{DynamicResource ChromeForegroundBrush}" HorizontalAlignment="Center"/>
      <TextBlock Text="Нативный просмотрщик markdown и кода"
                 Foreground="{DynamicResource ChromeForegroundMutedBrush}"
                 FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8"/>

      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <Button Content="Открыть файл…" Command="{Binding OpenFileCommand}"
                Classes="accent" Padding="18,9"/>
        <Button Content="Открыть пример" Command="{Binding OpenSampleCommand}"
                AutomationProperties.AutomationId="OpenSampleButton" Padding="18,9"/>
      </StackPanel>

      <StackPanel IsVisible="{Binding HasRecent}" Spacing="2" Margin="0,18,0,0">
        <TextBlock Text="Недавние" FontWeight="SemiBold" FontSize="12"
                   Foreground="{DynamicResource ChromeForegroundMutedBrush}" Margin="6,0,0,4"/>
        <ItemsControl ItemsSource="{Binding RecentFiles}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="x:String">
              <Button Content="{Binding}" ToolTip.Tip="{Binding}" Classes="recent"
                      Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenRecentCommand}"
                      CommandParameter="{Binding}"
                      Background="Transparent" BorderThickness="0"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                      Padding="8,5"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>
    </ScrollViewer>
  </Panel>
</UserControl>
